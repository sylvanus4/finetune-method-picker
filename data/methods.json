  "distillation": [
    {
      "id": "self-instruct",
      "name": "Self-Instruct / synthetic",
      "produces": "messages",
      "how": {
        "ko": "seed 예시 → teacher가 새 지시-응답 생성 → 품질/다양성 필터",
        "en": "seed examples → teacher generates new instruction-response → filter for quality/diversity"
      },
      "source": "https://arxiv.org/abs/2212.10560"
    },
    {
      "id": "on-policy",
      "name": "On-policy distillation (GKD)",
      "produces": "prompts (live teacher)",
      "how": {
        "ko": "student가 rollout 생성 → teacher가 per-token 교정 → exposure-bias 해소",
        "en": "student generates rollouts → teacher corrects per-token → fixes exposure bias"
      },
      "source": "https://arxiv.org/abs/2306.13649"
    },
    {
      "id": "rejection",
      "name": "Rejection sampling / best-of-N",
      "produces": "prompt-completion",
      "how": {
        "ko": "teacher N개 샘플 → verifier 통과분만 학습",
        "en": "teacher samples N → train only on verifier-passing ones"
      },
      "source": "https://arxiv.org/pdf/2406.19774"
    },
    {
      "id": "cot-trace",
      "name": "CoT-trace distillation",
      "produces": "prompt+trace+answer",
      "how": {
        "ko": "teacher의 추론 과정 전체를 student가 재현",
        "en": "student reproduces teacher's full reasoning trace"
      },
      "source": "https://arxiv.org/abs/2507.23751"
    }
  ],
