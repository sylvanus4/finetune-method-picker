  "tunings": [
    {
      "id": "full",
      "name": "Full fine-tune",
      "when": "GPU 여유 + 최고 품질, base 전체 갱신",
      "vramNote": "≈파라미터×16 byte (weight2+grad2+Adam8+master4) + 액티베이션 — 가장 무거움",
      "recommendLR": "1e-6 – 1e-5",
      "strategy": "FSDP/DeepSpeed ZeRO-3 권장",
      "source": "https://blog.eleuther.ai/transformer-math/"
    },
    {
      "id": "lora",
      "name": "LoRA",
      "when": "메모리 절약 + 대부분의 커스터마이징에 충분",
      "vramNote": "base 동결(2 byte/param) + 작은 어댑터만 학습 → 옵티마이저/그래디언트 ~10–20x↓",
      "recommendLR": "1e-4 – 3e-4",
      "strategy": "DDP 또는 FSDP",
      "source": "https://huggingface.co/docs/peft/en/task_guides/lora_based_methods"
    },
    {
      "id": "qlora",
      "name": "QLoRA",
      "when": "GPU가 빠듯할 때 (base를 4-bit로)",
      "vramNote": "base 4-bit NF4(~0.5 byte/param) + double-quant + 고정밀 어댑터 — 65B를 48GB 한 장에",
      "recommendLR": "1e-4 – 3e-4",
      "strategy": "paged optimizer와 함께",
      "source": "https://arxiv.org/pdf/2305.14314"
    }
  ],
